{
  "info": {
    "name": "RoadWatch API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for RoadWatch services with full CRUD endpoints and correct ports."
    "variable": [
    {"key": "road_host", "value": "{{road_host}}"},
    {"key": "budget_host", "value": "http://localhost:3002"},
    {"key": "complaint_host", "value": "http://localhost:3003"},
    {"key": "document_host", "value": "http://localhost:3004"},
    {"key": "search_host", "value": "http://localhost:3005"},
    {"key": "ai_host", "value": "http://localhost:3006"},
    {"key": "auth_host", "value": "http://localhost:3007"},
    {"key": "notification_host", "value": "http://localhost:3008"},
    {"key": "accessToken", "value": ""},
    {"key": "roadId", "value": "1"}
  ],
},
  "item": [
    {
      "name": "Road Service",
      "item": [
        {
          "name": "Get All Roads",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{road_host}}/api/v1/roads",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "roads"]
            }
          }
        },
        {
          "name": "Get Road By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{road_host}}/api/v1/roads/{{roadId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "roads", "1"]
            }
          }
        },
        {
          "name": "Create Road",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Main St\", \"length\": 5000}"
            },
            "url": {
              "raw": "{{road_host}}/api/v1/roads",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "roads"]
            }
          }
        },
        {
          "name": "Update Road",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Main St Updated\", \"length\": 5200}"
            },
            "url": {
              "raw": "{{road_host}}/api/v1/roads/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "roads", "1"]
            }
          }
        },
        {
          "name": "Delete Road",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{road_host}}/api/v1/roads/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "roads", "1"]
            }
          }
        }
      ]
    },
