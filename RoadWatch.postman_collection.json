              "protocol": "http",
              "host": ["localhost"],
              "port": "3007",
              "path": ["api", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"<token>\"}"
            },
            "url": {
              "raw": "http://localhost:3007/api/v1/auth/refresh",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3007",
              "path": ["api", "v1", "auth", "refresh"]
            }
          }
        }
      ]
