{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/road-service/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.json"
  },
  "monorepo": true,
  "root": "apps/road-service",
  "projects": {
    "road-service": {
      "type": "application",
      "root": "apps/road-service",
      "entryFile": "main",
      "sourceRoot": "apps/road-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/road-service/tsconfig.app.json"
      }
    },
    "budget-service": {
      "type": "application",
      "root": "apps/budget-service",
      "entryFile": "main",
      "sourceRoot": "apps/budget-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/budget-service/tsconfig.app.json"
      }
    },
    "complaint-service": {
      "type": "application",
      "root": "apps/complaint-service",
      "entryFile": "main",
      "sourceRoot": "apps/complaint-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/complaint-service/tsconfig.app.json"
      }
    },
    "document-service": {
      "type": "application",
      "root": "apps/document-service",
      "entryFile": "main",
      "sourceRoot": "apps/document-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/document-service/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    },
    "search-service": {
      "type": "application",
      "root": "apps/search-service",
      "entryFile": "main",
      "sourceRoot": "apps/search-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/search-service/tsconfig.app.json"
      }
    },
    "ai-gateway-service": {
      "type": "application",
      "root": "apps/ai-gateway-service",
      "entryFile": "main",
      "sourceRoot": "apps/ai-gateway-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ai-gateway-service/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}
