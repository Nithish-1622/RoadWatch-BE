{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2020",
    "lib": ["es2020"],
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "typeRoots": ["node_modules/@types"],
    "paths": {
      "@app/*": ["libs/*/src"],
      "@app/common": ["libs/common/src"]
    }
  },
  "exclude": ["node_modules", "dist"],
  "include": ["apps/**/*.ts", "apps/**/*.js", "libs/**/*.ts", "libs/**/*.js"]
}
